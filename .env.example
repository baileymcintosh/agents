# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER commit .env to git — it contains real secrets
# ============================================================

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Slack Integration ---
# Create a Slack app at https://api.slack.com/apps
# Add OAuth scopes: chat:write, files:write, channels:read
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
# Channel IDs where agents post reports
SLACK_EXECUTIVE_CHANNEL_ID=C0XXXXXXXXX
SLACK_ENGINEERING_CHANNEL_ID=C0XXXXXXXXX
SLACK_ALERTS_CHANNEL_ID=C0XXXXXXXXX

# --- Web Search (Tavily — free tier at https://tavily.com) ---
# Sign up free, go to dashboard, copy your API key
# This enables agents to search the web for current information
TAVILY_API_KEY=tvly-...

# --- GitHub (for PR/issue automation) ---
GITHUB_TOKEN=ghp_...
GITHUB_REPO=your-org/agents

# --- Agent Behavior ---
# How often nightly jobs run (cron format, handled by GitHub Actions)
NIGHTLY_CRON_SCHEDULE="0 2 * * *"
# Max tokens per agent run
AGENT_MAX_TOKENS=8000
# Model to use
AGENT_MODEL=claude-opus-4-6

# --- Reporting ---
REPORTS_DIR=./reports
PDF_EXPORT_ENABLED=true
