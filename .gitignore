# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# uv
.uv/

# Environment variables (NEVER commit real secrets)
.env
.env.local

# Testing
.pytest_cache/
pytest-cache-files-*/
.pytest_tmp/
.coverage
htmlcov/
.tox/

# Temp dirs created by tests / runtime
tmp*/
reports/_test_tmp/
_state/

# Runtime clock metadata — never commit, stale files cause instant time-budget exhaustion
.run_meta.json
reports/.run_meta.json

# Type checking
.mypy_cache/
.ruff_cache/

# IDE
.vscode/settings.json
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Docker
*.dockerignore

# Reports output (generated files, not templates)
reports/*.pdf
reports/*.html

# Notebooks checkpoints
.ipynb_checkpoints/

# Data (large files)
data/raw/
data/processed/
*.csv
*.parquet
*.db
